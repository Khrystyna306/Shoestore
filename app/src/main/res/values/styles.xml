<resources>

    <!-- Стиль для полів вводу -->
    <style name="FormField">
        <item name="android:layout_width">300dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <!-- Стиль для кнопки -->
    <style name="PrimaryButton">
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginTop">20dp</item>
    </style>

    <style name="SecondaryButton">
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:backgroundTint">@color/input_border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>
    <style name="WelcomeText">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/textColor</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>